# =====================================================
# VARIABLES DE ENTORNO - FORMATO DE PEDIDOS ROCOTO
# =====================================================
# Copia este archivo como .env.local y completa los valores

# ── Google Gemini AI ──────────────────────────────
GEMINI_API_KEY=tu_gemini_api_key_aqui

# ── Google Sheets API ─────────────────────────────
# ID de tu Google Spreadsheet (en la URL: /spreadsheets/d/ESTE_ID/edit)
VITE_SHEETS_ID=1Yhpeb3aOJiW05XIEWcMPIjLl_ibr9xVa

# API Key de Google Cloud (con permiso "Google Sheets API" habilitado)
# Pasos para obtenerla:
#   1. Ve a https://console.cloud.google.com
#   2. Crea un proyecto (o usa uno existente)
#   3. Habilita "Google Sheets API" en APIs y Servicios
#   4. Crea una Credencial tipo "API Key"
#   5. Restringe la key a tu dominio (Vercel / localhost)
VITE_SHEETS_API_KEY=tu_google_sheets_api_key_aqui

# ── Firebase Configuration ────────────────────────
# Estas se leen desde firebase-applet-config.json automaticamente
# Si necesitas sobrescribir individualmente:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
