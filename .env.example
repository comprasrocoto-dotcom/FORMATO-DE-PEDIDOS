# ============================================================
# InsumoMaster — Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# ============================================================

# --- Gemini AI (inyectado automáticamente por AI Studio) ---
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"

# --- Google Sheets API ---
# 1. Ve a console.cloud.google.com
# 2. Crea proyecto → Habilita "Google Sheets API"
# 3. Credenciales → Crear → Clave de API
# 4. Restringe la clave a Google Sheets API + tu dominio
VITE_SHEETS_API_KEY="TU_GOOGLE_SHEETS_API_KEY"

# La hoja ya está configurada en sheetsService.ts:
# SpreadsheetID: 1Yhpeb3aOJiW05XIEWcMPIjLl_ibr9xVa
# IMPORTANTE: La hoja debe ser pública (Compartir → Cualquiera con el enlace → Lector)

# --- EmailJS (correos de confirmación) ---
# 1. Crea cuenta gratis en https://emailjs.com (200 correos/mes gratis)
# 2. Email Services → Conecta tu Gmail
# 3. Email Templates → Crea template con estas variables:
#    {{to_email}}, {{to_name}}, {{numero_pedido}}, {{proveedor}},
#    {{sede}}, {{direccion}}, {{horario}}, {{fecha}},
#    {{responsable}}, {{notas}}, {{items_html}}, {{total}}
# 4. Account → API Keys → copia tu Public Key
VITE_EMAILJS_SERVICE_ID="service_xxxxxxx"
VITE_EMAILJS_TEMPLATE_ID="template_xxxxxxx"
VITE_EMAILJS_PUBLIC_KEY="tu_public_key_emailjs"
