{
  "entities": {
    "Insumo": {
      "title": "Insumo",
      "description": "Un producto o suministro utilizado en la operación.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "categoria": { "type": "string" },
        "unidad": { "type": "string" },
        "precio": { "type": "number" },
        "proveedorId": { "type": "string" },
        "actualizadoAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nombre", "unidad", "precio", "proveedorId"]
    },
    "Proveedor": {
      "title": "Proveedor",
      "description": "Empresa o persona que suministra insumos.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "contacto": { "type": "string" },
        "email": { "type": "string" },
        "telefono": { "type": "string" }
      },
      "required": ["nombre"]
    },
    "Sede": {
      "title": "Sede",
      "description": "Punto de venta o sucursal donde se reciben los pedidos.",
      "type": "object",
      "properties": {
        "nombre": { "type": "string" },
        "direccion": { "type": "string" },
        "horario": { "type": "string" }
      },
      "required": ["nombre", "direccion", "horario"]
    },
    "Configuracion": {
      "title": "Configuración",
      "description": "Ajustes globales como los consecutivos de las órdenes.",
      "type": "object",
      "properties": {
        "consecutivoGlobal": { "type": "number" },
        "consecutivoPorProveedor": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/insumos/{insumoId}": {
      "schema": "Insumo",
      "description": "Catálogo de insumos."
    },
    "/proveedores/{proveedorId}": {
      "schema": "Proveedor",
      "description": "Catálogo de proveedores."
    },
    "/sedes/{sedeId}": {
      "schema": "Sede",
      "description": "Lista de sedes configuradas."
    },
    "/config/global": {
      "schema": "Configuracion",
      "description": "Configuración global de la aplicación (consecutivos)."
    }
  }
}
