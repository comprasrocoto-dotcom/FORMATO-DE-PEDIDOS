rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidInsumo(data) {
      return data.keys().hasAll(['nombre', 'unidad', 'precio', 'proveedorId']) 
        && data.nombre is string && data.nombre.size() > 0 && data.nombre.size() <= 200
        && data.unidad is string && data.unidad.size() > 0 && data.unidad.size() <= 50
        && data.precio is number && data.precio >= 0
        && data.proveedorId is string && data.proveedorId.size() > 0;
    }

    function isValidSede(data) {
      return data.keys().hasAll(['nombre', 'direccion', 'horario'])
        && data.nombre is string && data.nombre.size() > 0
        && data.direccion is string && data.direccion.size() > 0
        && data.horario is string && data.horario.size() > 0;
    }

    function isValidConfig(data) {
      return data.consecutivoGlobal is number && data.consecutivoGlobal >= 0;
    }

    // --- Rules ---

    match /insumos/{insumoId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidInsumo(incoming());
    }

    match /proveedores/{proveedorId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Basic check
    }

    match /sedes/{sedeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidSede(incoming());
    }

    match /config/global {
      allow read: if isSignedIn();
      allow update: if isSignedIn() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['consecutivoGlobal'])
        && incoming().consecutivoGlobal == existing().consecutivoGlobal + 1;
      allow create: if isSignedIn() && isValidConfig(incoming());
    }
  }
}
